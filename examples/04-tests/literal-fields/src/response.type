ResponseSuccess: {
  status: "success",
  value: string,
}

ResponseFailure: {
  status: "failure",
  error: string,
}

Response:
  | ResponseSuccess
  | ResponseFailure

LiteralBag: {
  kind: "demo",
  enabled: true,
  code: 200,
  empty: null,
}

RemoveFileRequest: {
  requestType: "remove-file",
  request_kind: "file-operation",
  filePath: string,
  retry_count: int,
}
