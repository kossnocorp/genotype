{
  "name": "Genotype",
  "scopeName": "source.genotype",
  "fileTypes": ["type"],
  "aliases": ["type", "genotype"],
  "patterns": [
    {
      "include": "#moduleDoc"
    },
    {
      "include": "#lineDoc"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#attribute"
    },
    {
      "include": "#alias"
    }
  ],
  "repository": {
    "alias": {
      "patterns": [
        {
          "begin": "^\\s*([A-Za-z][A-Za-z0-9_]*)\\s*(:)",
          "end": "(?=^(?:\\s*//!|\\s*///|\\s*use\\b|\\s*[A-Za-z][A-Za-z0-9_]*\\s*:)|\\z)",
          "name": "meta.alias.genotype",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.alias.genotype"
            },
            "2": {
              "name": "punctuation.separator.key-value.genotype"
            }
          },
          "patterns": [
            {
              "include": "#descriptors"
            },
            {
              "include": "#attribute"
            },
            {
              "include": "#lineDoc"
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "descriptors": {
      "patterns": [
        {
          "match": "\\|",
          "name": "keyword.operator.union.genotype"
        },
        {
          "include": "#descriptor"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "descriptor": {
      "patterns": [
        {
          "include": "#attribute"
        },
        {
          "include": "#record"
        },
        {
          "include": "#object"
        },
        {
          "include": "#array"
        },
        {
          "include": "#tuple"
        },
        {
          "include": "#inlineImport"
        },
        {
          "include": "#branded"
        },
        {
          "include": "#literals"
        },
        {
          "include": "#primitive"
        },
        {
          "match": "\\bany\\b",
          "name": "storage.type.any.genotype"
        },
        {
          "include": "#identifier"
        }
      ]
    },
    "attribute": {
      "begin": "#\\[",
      "end": "\\]",
      "name": "meta.annotation.genotype",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.annotation.begin.genotype"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.annotation.end.genotype"
        }
      },
      "patterns": [
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b(\\s*=\\s*)([A-Za-z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.genotype"
            },
            "2": {
              "name": "keyword.operator.assignment.genotype"
            },
            "3": {
              "name": "entity.name.type.genotype"
            }
          }
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b(?=\\s*\\()",
          "name": "entity.name.function.annotation.genotype"
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b(?=\\s*=)",
          "name": "entity.other.attribute-name.genotype"
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b(?=\\s*\\])",
          "name": "entity.other.attribute-name.genotype"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.genotype"
        },
        {
          "begin": "\\(",
          "end": "\\)",
          "name": "meta.annotation.arguments.genotype",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.group.begin.genotype"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.group.end.genotype"
            }
          },
          "patterns": [
            {
              "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b\\s*(=)",
              "captures": {
                "1": {
                  "name": "variable.other.property.genotype"
                },
                "2": {
                  "name": "keyword.operator.assignment.genotype"
                }
              }
            },
            {
              "include": "#attributeValue"
            },
            {
              "match": ",",
              "name": "punctuation.separator.comma.genotype"
            },
            {
              "include": "#comments"
            }
          ]
        },
        {
          "include": "#attributeValue"
        }
      ]
    },
    "attributeValue": {
      "patterns": [
        {
          "include": "#literals"
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b",
          "name": "entity.name.type.genotype"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "begin": "^\\s*(use)\\b",
          "end": "(?=$)",
          "name": "meta.import.genotype",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.genotype"
            }
          },
          "patterns": [
            {
              "include": "#path"
            },
            {
              "include": "#importReference"
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "importReference": {
      "patterns": [
        {
          "match": "\\*",
          "name": "keyword.operator.wildcard.genotype"
        },
        {
          "begin": "\\{",
          "end": "\\}",
          "name": "meta.import.names.genotype",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.block.begin.genotype"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.genotype"
            }
          },
          "patterns": [
            {
              "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b\\s+(as)\\s+([A-Za-z][A-Za-z0-9_]*)\\b",
              "captures": {
                "1": {
                  "name": "entity.name.type.genotype"
                },
                "2": {
                  "name": "keyword.control.import.as.genotype"
                },
                "3": {
                  "name": "entity.name.type.alias.genotype"
                }
              }
            },
            {
              "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b",
              "name": "entity.name.type.genotype"
            },
            {
              "match": ",",
              "name": "punctuation.separator.comma.genotype"
            },
            {
              "include": "#comments"
            }
          ]
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b",
          "name": "entity.name.type.genotype"
        }
      ]
    },
    "path": {
      "patterns": [
        {
          "match": "\\.\\./",
          "name": "keyword.operator.path.parent.genotype"
        },
        {
          "match": "\\./",
          "name": "keyword.operator.path.current.genotype"
        },
        {
          "match": "[^/\\s]+(?=/)",
          "name": "entity.name.namespace.genotype"
        },
        {
          "match": "/",
          "name": "punctuation.separator.path.genotype"
        }
      ]
    },
    "inlineImport": {
      "begin": "(?=(?:\\.\\./|\\./|[^/\\s]+/)+[A-Za-z][A-Za-z0-9_]*\\b)",
      "end": "(?=\\s|,|\\]|\\}|\\)|\\||$)",
      "name": "meta.inline-import.genotype",
      "patterns": [
        {
          "include": "#path"
        },
        {
          "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\b",
          "name": "entity.name.type.genotype"
        }
      ]
    },
    "primitive": {
      "match": "\\b(boolean|string|number|int|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|float|f32|f64)\\b",
      "name": "storage.type.primitive.genotype"
    },
    "branded": {
      "match": "(@)(boolean|string|number|int|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|float|f32|f64)\\b",
      "captures": {
        "1": {
          "name": "storage.modifier.branded.genotype"
        },
        "2": {
          "name": "storage.type.primitive.genotype"
        }
      }
    },
    "literals": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.genotype",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.genotype"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.genotype"
            }
          },
          "patterns": [
            {
              "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9A-Fa-f]{4})",
              "name": "constant.character.escape.genotype"
            }
          ]
        },
        {
          "match": "\\b(?:true|false)\\b",
          "name": "constant.language.boolean.genotype"
        },
        {
          "match": "\\bnull\\b",
          "name": "constant.language.null.genotype"
        },
        {
          "match": "[+-]?(?:0|[1-9](?:[0-9]|_[0-9])*)(?:\\.(?:[0-9]|_[0-9])+(?:[eE][+-]?[0-9]+)?|[eE][+-]?[0-9]+)",
          "name": "constant.numeric.float.genotype"
        },
        {
          "match": "[+-]?(?:0|[1-9](?:[0-9]|_[0-9])*)",
          "name": "constant.numeric.integer.genotype"
        }
      ]
    },
    "object": {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.object.type.genotype",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.block.begin.genotype"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.genotype"
        }
      },
      "patterns": [
        {
          "include": "#lineDoc"
        },
        {
          "include": "#attribute"
        },
        {
          "include": "#extensionProperty"
        },
        {
          "include": "#property"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.genotype"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "extensionProperty": {
      "match": "(\\.\\.\\.)([A-Za-z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.operator.spread.genotype"
        },
        "2": {
          "name": "entity.name.type.genotype"
        }
      }
    },
    "property": {
      "begin": "\\b([A-Za-z][A-Za-z0-9_]*)\\b\\s*(\\?)?\\s*(:)",
      "end": "(?=,|\\}|$)",
      "name": "meta.property.genotype",
      "beginCaptures": {
        "1": {
          "name": "variable.other.property.genotype"
        },
        "2": {
          "name": "keyword.operator.optional.genotype"
        },
        "3": {
          "name": "punctuation.separator.key-value.genotype"
        }
      },
      "patterns": [
        {
          "include": "#descriptors"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "record": {
      "begin": "\\{(?=\\s*\\[)",
      "end": "\\}",
      "name": "meta.record.type.genotype",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.block.begin.genotype"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.genotype"
        }
      },
      "patterns": [
        {
          "begin": "\\[(?=[^\\]]*\\]\\s*:)",
          "end": "\\]",
          "name": "meta.record.key.genotype",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.brackets.begin.genotype"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.brackets.end.genotype"
            }
          },
          "patterns": [
            {
              "include": "#primitive"
            },
            {
              "include": "#comments"
            }
          ]
        },
        {
          "match": ":",
          "name": "punctuation.separator.key-value.genotype"
        },
        {
          "include": "#descriptors"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "array": {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.array.type.genotype",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.brackets.begin.genotype"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.brackets.end.genotype"
        }
      },
      "patterns": [
        {
          "include": "#descriptors"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "tuple": {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.tuple.type.genotype",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.group.begin.genotype"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.section.group.end.genotype"
        }
      },
      "patterns": [
        {
          "include": "#descriptors"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.genotype"
        },
        {
          "include": "#comments"
        }
      ]
    },
    "identifier": {
      "match": "\\b(?!use\\b|as\\b|true\\b|false\\b|null\\b|any\\b|boolean\\b|string\\b|number\\b|int\\b|i8\\b|i16\\b|i32\\b|i64\\b|i128\\b|isize\\b|u8\\b|u16\\b|u32\\b|u64\\b|u128\\b|usize\\b|float\\b|f32\\b|f64\\b)[A-Za-z][A-Za-z0-9_]*\\b",
      "name": "entity.name.type.genotype"
    },
    "moduleDoc": {
      "match": "^\\s*//!.*$",
      "name": "comment.block.documentation.genotype"
    },
    "lineDoc": {
      "match": "^\\s*///.*$",
      "name": "comment.line.documentation.genotype"
    },
    "comments": {
      "patterns": [
        {
          "match": "//(?![/!]).*$",
          "name": "comment.line.double-slash.genotype"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.genotype",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    }
  }
}
