{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2024",
    "lib": ["ES2024"],
    "rootDir": "src",
    "sourceMap": true,
    "skipLibCheck": true,
    // Output
    // TODO: Make a separate tsconfig.dist.json
    "outDir": "dist/dev",
    // "outDir": "./.ts",
    "tsBuildInfoFile": "./.ts/tsconfig.tsbuildinfo",
    "emitDeclarationOnly": true,
    // Build
    "incremental": true,
    // Project references
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
