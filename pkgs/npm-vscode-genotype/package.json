{
  "name": "genotype",
  "displayName": "Genotype",
  "version": "0.2.0",
  "description": "Genotype language support",
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "author": "Sasha Koss <koss@nocorp.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kossnocorp/genotype.git"
  },
  "publisher": "nocorp",
  "files": [
    "extension.js",
    "syntaxes",
    "language-configuration.json",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "main": "./dist/dev/extension.js",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/vscode": "^1.115.0",
    "@vscode/vsce": "^3.7.1",
    "genotype-lsp": "workspace:*",
    "genotype-tm-grammar": "workspace:*",
    "ovsx": "^0.10.10",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Multi LSP configuration",
      "properties": {
        "genotype.server.executable": {
          "type": "object",
          "default": {},
          "description": "Genotype LSP server executable options"
        }
      }
    },
    "languages": [
      {
        "id": "genotype",
        "aliases": [
          "Genotype",
          "genotype"
        ],
        "extensions": [
          "type"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "genotype",
        "scopeName": "source.genotype",
        "path": "./node_modules/genotype-tm-grammar/genotype.json"
      }
    ]
  },
  "engines": {
    "vscode": "^1.115.0"
  }
}
