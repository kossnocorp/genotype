{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vscode:build",
      "type": "shell",
      "command": "mise",
      "args": [":build"],
      "options": {
        "cwd": "${workspaceFolder}/pkgs/npm-vscode-genotype"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    // TODO: Revamp
    {
      "label": "Build CLI",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--bin", "gt"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
