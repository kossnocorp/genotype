{
  "version": "2.0.0",
  "tasks": [
    //#region website

    // website#dev
    {
      "type": "shell",
      "label": "website#dev",
      "command": "mise",
      "args": ["//pkgs/app-website:dev"],
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(.*)\\((\\d+,\\d+)\\):\\s+(error|warning|info)\\s+TS(\\d+):\\s+(.*)$",
            "file": 1,
            "location": 2,
            "severity": 3,
            "code": 4,
            "message": 5
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*ready in.*",
          "endsPattern": ".*ready in.*"
        }
      }
    },

    //#endregion

    //#region vscode

    {
      "label": "vscode:build",
      "type": "shell",
      "command": "mise",
      "args": [":build"],
      "options": {
        "cwd": "${workspaceFolder}/pkgs/npm-vscode-genotype"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    //#endregion

    // TODO: Revamp
    {
      "label": "Build CLI",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--bin", "gt"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
